{
  "name": "babycare-backend",
  "version": "1.0.0",
  "description": "BabyCare backend API",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "dev:all": "kill-port 5000 5173 && concurrently \"npm run dev\" \"npm run client\"",
    "client": "vite frontend/src --config frontend/vite.config.mjs --port 5173",
    "build": "npm run build:client",
    "build:client": "vite build frontend/src --config frontend/vite.config.mjs --outDir ../dist",
    "preview:client": "vite preview frontend/dist"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.15.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.10",
    "vite": "^5.4.11"
  }
}
